<%@ Page Language="C#" MasterPageFile="~/MasterPage.Master" AutoEventWireup="true" CodeBehind="SupportFAQ.aspx.cs" Inherits="ImageSolutionsWebsite.SupportFAQ" %>

<asp:Content ID="Content1" ContentPlaceHolderID="head" runat="server">
</asp:Content>
<asp:Content ID="Content2" ContentPlaceHolderID="cphHeader" runat="server">
</asp:Content>
<asp:Content ID="Content3" ContentPlaceHolderID="cphBody" runat="server">
<section class="contact-page section-b-space">
    <div class="container">
        <div class="row section-b-space">
            <div class="col-lg-1">
            </div>
            <div class="col-lg-10">
                <h2 id="title">Support/FAQ</h2>
                <br />

                <h3>How do I contact support?</h3>
                <p>To contact support, call (888) 756-9898.</p>
                
                <h3>Can I track my order?</h3>
                <p>Yes. Once your order has shipped, you will receive an email confirmation containing the FedEX tracking number. Click on the FedEX link to view your order's tracking details.</p>

                <h3>How do I view my order history?</h3>
                <p>To view your order history, click on the My Account link above.</p>

                <h3>What is a “non-stock item”?</h3>
                <p>Non-stock items are available for purchase, but Image Solutions does not carry any stock. These items are processed upon customer request and typically take 10-12 business days for delivery.</p>

                <h3>How do I know if my order went through?</h3>
                <p>Once you reach the final checkout screen, click “Submit Order.” Once your order has been processed, you will receive a confirmation number and an email with the confirmation number.</p>
                
                <h3>How do I make a return or exchange?</h3>
                <p>To make a return or exchange, please see our <a href="ReturnPolicy.aspx">Return Policy</a></p>
                
            </div>
            <div class="col-lg-1">
            </div>            
        </div>
    </div>
    
</section>
</asp:Content>